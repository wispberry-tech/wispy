<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Wisp Documentation{% end %}</title>
  <link rel="stylesheet" href="/static/style.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; }
    aside { width: 260px; float: left; background: #f8f9fa; padding: 20px; height: 100vh; overflow-y: auto; position: fixed; }
    main { margin-left: 280px; padding: 40px; max-width: 900px; }
    aside h3 { color: #333; margin: 20px 0 10px 0; font-size: 14px; text-transform: uppercase; }
    aside ul { list-style: none; padding: 0; }
    aside li { margin: 5px 0; }
    aside a { color: #555; text-decoration: none; display: block; padding: 5px 10px; border-radius: 4px; }
    aside a:hover { background: #e9ecef; color: #0066cc; }
    h1 { color: #333; margin-bottom: 20px; }
    h2 { color: #555; margin: 30px 0 15px 0; }
    h3 { color: #666; margin: 20px 0 10px 0; }
    ul { margin: 15px 0; padding-left: 25px; }
    li { margin-bottom: 8px; }
    pre { background: #f5f5f5; padding: 15px; border: 1px solid #ddd; overflow-x: auto; margin: 10px 0; }
    code { font-family: "Monaco", "Menlo", monospace; }
    a { color: #0066cc; }
  </style>
</head>
<body>
  <aside>
    <a href="/" style="display: block; padding: 10px; background: #0066cc; color: white; text-decoration: none; border-radius: 4px; margin-bottom: 20px;">Wisp Docs</a>
    <h3>Getting Started</h3>
    <ul>
      <li><a href="/docs/getting-started">Getting Started</a></li>
      <li><a href="/docs/engine">Engine Architecture</a></li>
      <li><a href="/docs/best-practices">Best Practices</a></li>
    </ul>
    <h3>Core Concepts</h3>
    <ul>
      <li><a href="/docs/templates">Template Composition</a></li>
      <li><a href="/docs/layouts">Layout System</a></li>
      <li><a href="/docs/security">Security</a></li>
      <li><a href="/docs/troubleshooting">Troubleshooting</a></li>
    </ul>
    <h3>Integrations</h3>
    <ul>
      <li><a href="/docs/chi">Chi Router</a></li>
    </ul>
  </aside>
  <main>
    {% block body %}{% end %}
  </main>
</body>
</html>