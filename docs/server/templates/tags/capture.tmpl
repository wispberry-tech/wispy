{% extends "layouts/doc-layout" %}

{% block title %}Capture Tag - Wisp Template Documentation{% end %}

{% block body %}
<h1>Capture Tag</h1>

<p>Captures output into a variable.</p>

<h2>Syntax</h2>
<pre><code>{% raw %}
{% capture variable %}...{% endcapture %}
{% endraw %}</code></pre>

<h2>Examples</h2>
<pre><code>{% raw %}
{% capture greeting %}
  Hello, {% .name%}!
{% endcapture %}
{% .greeting%}
{% endraw %}</code></pre>

<h2>See Also</h2>
<ul>
  <li><a href="/docs/tags/assign">assign tag</a></li>
</ul>
{% end %}
