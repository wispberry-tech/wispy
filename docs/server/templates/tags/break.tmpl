{% extends "layouts/doc-layout" %}

{% block title %}Break Tag - Wisp Template Documentation{% end %}

{% block body %}
<h1>Break Tag</h1>

<p>Exits a loop early.</p>

<h2>Syntax</h2>
<pre><code>{% break %}</code></pre>

<h2>Examples</h2>
<pre><code>{% for .item in .items %}
{% if .item.stop %}
  {% break %}
{% end %}
{%.item.name%}
{% end %}</code></pre>

