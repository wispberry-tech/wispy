{% extends "layouts/doc-layout" %}

{% block title %}Increment Tag - Wisp Template Documentation{% end %}

{% block body %}
<h1>Increment Tag</h1>

<p>Increments a counter variable and returns its value.</p>

<h2>Syntax</h2>
<pre><code>{% raw %}
{% increment variable %}
{% endraw %}</code></pre>

<h2>Examples</h2>
<pre><code>{% raw %}
{% increment counter %}
{% increment counter %}
{% increment counter %}
{% endraw %}</code></pre>
<p><strong>Output:</strong> 0 1 2</p>

<h2>Notes</h2>
<ul>
  <li>Global counter, persists across renders</li>
  <li>Returns value before incrementing</li>
</ul>

<h2>See Also</h2>
<ul>
  <li><a href="/docs/tags/decrement">decrement tag</a></li>
</ul>
{% end %}
