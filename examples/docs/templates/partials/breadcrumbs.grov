<Component name="Breadcrumbs" breadcrumbs>
{% asset "/css/partials/breadcrumbs.css" type="stylesheet" %}
<nav class="breadcrumb-bar" aria-label="Page breadcrumb">
  {% #each breadcrumbs as crumb %}
    {% #if crumb.href %}
      <a href="{% crumb.href %}">{% crumb.label %}</a>
      <span class="breadcrumb-sep">/</span>
    {% :else %}
      <span class="breadcrumb-current">{% crumb.label %}</span>
    {% /if %}
  {% /each %}
</nav>
</Component>
